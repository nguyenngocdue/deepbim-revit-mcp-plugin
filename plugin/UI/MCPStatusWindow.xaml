<Window x:Class="revit_mcp_plugin.UI.MCPStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepBim-MCP Server Control" Height="441" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/RevitMCPPlugin;component/Resources/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="DeepBim-MCP Server" Style="{StaticResource TextHeader}" FontSize="20"/>
            <TextBlock Text="AI-Powered BIM Automation for Revit"
                       Style="{StaticResource TextSubHeader}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Status Panel -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,8"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12"
                             Fill="#ccc" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Stopped" FontSize="14"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Port -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PortText" Text="—" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>

                <!-- Plugin Dir -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" FontWeight="SemiBold"
                           VerticalAlignment="Top" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PluginDirText"
                           Text="—" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Log Area -->
        <Border Grid.Row="2" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,15" Background="White">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" Padding="8" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="Start" Style="{StaticResource PrimaryButton}"
                    Width="90" Margin="0,0,10,0" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop" Style="{StaticResource CancelButton}"
                    Width="90" Margin="0,0,10,0"
                    IsEnabled="False" Click="StopButton_Click"/>
            <Button Content="Close" Style="{StaticResource SecondaryButton}"
                    Width="90" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
