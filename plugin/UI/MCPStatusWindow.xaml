<Window x:Class="revit_mcp_plugin.UI.MCPStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DeepBim-MCP Server Control" Height="441" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border x:Name="RootBorder" Background="#F8F9FA" CornerRadius="10" BorderBrush="#D6F5F2" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="20" ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar (đồng bộ ToolWindow) -->
            <Border Grid.Row="0" Background="#334155" CornerRadius="9,9,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" x:Name="TitleBarIcon" Width="20" Height="20" Margin="14,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBlock Grid.Column="1" Text="DeepBim-MCP Server Control" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="CloseButton" Content="✕" Width="44" Height="44" Margin="0"
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"
                            ToolTip="Close" Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="DeepBim-MCP Server" FontSize="18" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock Text="AI-Powered BIM Automation for Revit" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status Panel -->
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.06" BlurRadius="6" Direction="315" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Center" Margin="0,0,12,8"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="#9A9A9A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="Stopped" FontSize="14" FontWeight="SemiBold" Foreground="#71717A" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Center" Margin="0,0,12,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PortText" Text="—" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Top" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PluginDirText" Text="—" Foreground="#666666" TextWrapping="Wrap" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Log Area -->
                <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.06" BlurRadius="6" Direction="315" ShadowDepth="1"/>
                    </Border.Effect>
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogText" Padding="10" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Foreground="#666666"/>
                    </ScrollViewer>
                </Border>

                <!-- Buttons (style inline DeepBim) -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="StartButton" Content="Start" Width="90" Height="36" Margin="0,0,8,0"
                            Background="#59DCCB" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Click="StartButton_Click"/>
                    <Button x:Name="StopButton" Content="Stop" Width="90" Height="36" Margin="0,0,8,0"
                            Background="#F4F4F5" Foreground="#71717A" BorderThickness="1" BorderBrush="#D4D4D4" FontWeight="SemiBold" Cursor="Hand"
                            IsEnabled="False" Click="StopButton_Click"/>
                    <Button Content="Close" Width="90" Height="36"
                            Background="#F4F4F5" Foreground="#71717A" BorderThickness="1" BorderBrush="#D4D4D4" FontWeight="SemiBold" Cursor="Hand" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
