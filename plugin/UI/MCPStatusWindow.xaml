<Window x:Class="revit_mcp_plugin.UI.MCPStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepBim-MCP Server Control" Height="441" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="DeepBim-MCP Server" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="AI-Powered BIM Automation for Revit"
                       Foreground="#666" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Status Panel -->
        <Border Grid.Row="1" Background="#f8f8f8" CornerRadius="6"
                BorderBrush="#e0e0e0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,8"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12"
                             Fill="#ccc" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Stopped" FontSize="14"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Port -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PortText" Text="—" Foreground="#444"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>

                <!-- Plugin Dir -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" FontWeight="SemiBold"
                           VerticalAlignment="Top" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PluginDirText"
                           Text="—" Foreground="#444" TextWrapping="Wrap" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Log Area -->
        <Border Grid.Row="2" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,15">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" Padding="8" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="#444"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="Start" Width="90" Height="32"
                    Background="#0078D7" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Margin="0,0,10,0"
                    Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop" Width="90" Height="32"
                    Background="#D74C00" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Margin="0,0,10,0"
                    IsEnabled="False" Click="StopButton_Click"/>
            <Button Content="Close" Width="90" Height="32"
                    BorderThickness="1" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
