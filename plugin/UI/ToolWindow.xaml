<Window x:Class="revit_mcp_plugin.UI.ToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DeepBim-MCP"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen">
    <Border x:Name="RootBorder" Background="#F8F9FA" CornerRadius="10" BorderBrush="#D6F5F2" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="20" ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#334155" CornerRadius="9,9,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" x:Name="TitleBarIcon" Width="20" Height="20" Margin="14,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBlock Grid.Column="1" x:Name="TitleText" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="CloseButton" Content="✕" Width="44" Height="44" Margin="0"
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"
                            ToolTip="Close" Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="CloseButton_Click"/>
                </Grid>
            </Border>
            <Frame Grid.Row="1" x:Name="ContentHost" NavigationUIVisibility="Hidden" BorderThickness="0" Background="Transparent"/>
        </Grid>
    </Border>
</Window>
